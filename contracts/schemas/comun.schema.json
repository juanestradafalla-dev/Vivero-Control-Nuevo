{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/comun.schema.json",
  "title": "Definiciones comunes",
  "$defs": {
    "idGlobal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Identificador global no derivado de una secuencia autoincremental local."
    },
    "idRutaSegura": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$",
      "description": "Identificador sin separadores de ruta, validado antes de construir referencias Firestore."
    },
    "timestampServidor": {
      "type": "string",
      "format": "date-time",
      "description": "Instante autoritativo asignado por el servidor."
    },
    "claveIdempotencia": {
      "type": "string",
      "minLength": 8,
      "maxLength": 160,
      "description": "Clave global estable para repetir una solicitud sin duplicar efectos."
    },
    "enteroNoNegativo": {
      "type": "integer",
      "minimum": 0
    },
    "ubicacionVisible": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vivero", "modulo", "cama", "linea", "nombreVisible", "orden"],
      "properties": {
        "vivero": {"type": "string", "minLength": 1, "maxLength": 120},
        "modulo": {"type": "string", "minLength": 1, "maxLength": 120},
        "cama": {"type": "string", "minLength": 1, "maxLength": 120},
        "linea": {"type": "string", "minLength": 1, "maxLength": 120},
        "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
        "orden": {"type": "integer", "minimum": 0}
      }
    }
  }
}
