{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/reserve-line-result.schema.json",
  "title": "ReserveLineResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["reservaId", "jornadaLineaId", "estadoCentral", "tokenReserva", "reservadaEn", "version", "ubicacion"],
  "properties": {
    "reservaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaLineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "estadoCentral": {"const": "EN_CONTEO"},
    "tokenReserva": {"type": "string", "minLength": 32, "maxLength": 512},
    "reservadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "version": {"type": "integer", "minimum": 1},
    "ubicacion": {"$ref": "comun.schema.json#/$defs/ubicacionVisible"}
  }
}
