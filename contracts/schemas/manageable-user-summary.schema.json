{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/manageable-user-summary.schema.json",
  "title": "Perfil administrable sin datos de Firebase Auth",
  "type": "object",
  "additionalProperties": false,
  "required": ["usuarioId", "nombreVisible", "rol", "activo", "version", "puedeCambiarRol", "resumenTrabajoActivo"],
  "properties": {
    "usuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 160},
    "rol": {"$ref": "../enums/roles.json"},
    "activo": {"type": "boolean"},
    "version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "puedeCambiarRol": {"type": "boolean"},
    "resumenTrabajoActivo": {"$ref": "user-active-work-summary.schema.json"}
  }
}
