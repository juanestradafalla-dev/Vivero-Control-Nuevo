{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/create-catalog-location-request.schema.json",
  "title": "Solicitud crearUbicacion",
  "type": "object",
  "additionalProperties": false,
  "required": ["codigo", "tipo", "ubicacionPadreId", "nombreVisible", "orden", "claveIdempotencia"],
  "properties": {
    "codigo": {"type": "string", "minLength": 1, "maxLength": 120, "pattern": ".*\\S.*"},
    "tipo": {"type": "string", "minLength": 1, "maxLength": 80, "pattern": ".*\\S.*"},
    "ubicacionPadreId": {"oneOf": [{"$ref": "comun.schema.json#/$defs/idRutaSegura"}, {"type": "null"}]},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 240, "pattern": ".*\\S.*"},
    "orden": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "claveIdempotencia": {"$ref": "comun.schema.json#/$defs/claveIdempotencia"}
  }
}
