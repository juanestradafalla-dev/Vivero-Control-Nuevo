{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/reserva.schema.json",
  "title": "Reserva",
  "description": "Reserva central sin expiración automática durante el MVP. Solo una operación explícita puede consumirla o liberarla.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "jornadaId",
    "jornadaLineaId",
    "usuarioId",
    "usuarioNombreVisible",
    "rolEfectivo",
    "dispositivoId",
    "claveIdempotencia",
    "tokenReservaHash",
    "reservadaEn",
    "estadoReserva",
    "politicaLiberacion"
  ],
  "properties": {
    "id": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "tipoReserva": {"enum": ["INICIAL", "CORRECCION"]},
    "conteoAnteriorId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "conteoId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "responsableCorreccionUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "reasignacionOrigenId": {
      "oneOf": [
        {"$ref": "comun.schema.json#/$defs/idGlobal"},
        {"type": "null"}
      ]
    },
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaLineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "usuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "usuarioNombreVisible": {"type": "string", "minLength": 1, "maxLength": 160},
    "rolEfectivo": {"$ref": "../enums/roles.json"},
    "dispositivoId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "claveIdempotencia": {"$ref": "comun.schema.json#/$defs/claveIdempotencia"},
    "tokenReservaHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Solo se persiste el hash. El token opaco se entrega al titular mediante el resultado idempotente."
    },
    "reservadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "ultimoContactoServidor": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "estadoReserva": {"$ref": "../enums/estados-reserva.json"},
    "liberadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "consumidaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "liberadaPorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "liberacionId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "motivoLiberacion": {"type": "string", "minLength": 1, "maxLength": 2000},
    "politicaLiberacion": {"const": "MANUAL_SUPERVISOR_MVP"}
  },
  "allOf": [
    {
      "if": {"properties": {"estadoReserva": {"const": "CONSUMIDA"}}},
      "then": {
        "properties": {"consumidaEn": {}, "conteoId": {}},
        "required": ["consumidaEn", "conteoId"]
      }
    },
    {
      "if": {"properties": {"estadoReserva": {"const": "LIBERADA"}}},
      "then": {
        "properties": {
          "liberadaEn": {},
          "liberadaPorUsuarioId": {},
          "motivoLiberacion": {},
          "liberacionId": {}
        },
        "required": ["liberadaEn", "liberadaPorUsuarioId", "motivoLiberacion", "liberacionId"]
      }
    },
    {
      "if": {"properties": {"tipoReserva": {"const": "CORRECCION"}}, "required": ["tipoReserva"]},
      "then": {
        "properties": {"conteoAnteriorId": {}},
        "required": ["conteoAnteriorId"]
      }
    }
  ]
}
