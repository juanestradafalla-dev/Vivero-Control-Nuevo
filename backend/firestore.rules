rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function activeUser() {
      return userExists() && currentUser().activo == true;
    }

    function isAdmin() {
      return activeUser() && 'ADMINISTRADOR' in currentUser().roles;
    }

    function hasJourneyAccess(journeyId) {
      let authorization = get(/databases/$(database)/documents/jornadas/$(journeyId)/autorizaciones/$(request.auth.uid)).data;
      return activeUser() &&
        exists(/databases/$(database)/documents/jornadas/$(journeyId)/autorizaciones/$(request.auth.uid)) &&
        authorization.activa == true;
    }

    function canSupervise(journeyId) {
      let authorization = get(/databases/$(database)/documents/jornadas/$(journeyId)/autorizaciones/$(request.auth.uid)).data;
      return hasJourneyAccess(journeyId) &&
        authorization.rolEfectivo in ['SUPERVISOR', 'ADMINISTRADOR'];
    }

    function assignedToCurrentCorrection(journeyLineId, countId) {
      let line = get(/databases/$(database)/documents/jornadaLineas/$(journeyLineId)).data;
      return activeUser() &&
        line.estadoCentral == 'DEVUELTA' &&
        line.conteoVigenteId == countId &&
        line.responsableCorreccionUsuarioId == request.auth.uid;
    }

    match /usuarios/{usuarioId} {
      allow get: if activeUser() && (request.auth.uid == usuarioId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /ubicaciones/{ubicacionId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /lineas/{lineaId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /jornadas/{jornadaId} {
      allow read: if hasJourneyAccess(jornadaId);
      allow write: if false;

      match /autorizaciones/{usuarioId} {
        allow read: if request.auth.uid == usuarioId || canSupervise(jornadaId);
        allow write: if false;
      }
    }

    match /jornadaLineas/{jornadaLineaId} {
      allow read: if hasJourneyAccess(resource.data.jornadaId);
      allow write: if false;
    }

    match /seleccionesLineasJornada/{jornadaId} {
      allow read, write: if false;
    }

    match /reservas/{reservaId} {
      allow read: if activeUser() &&
        (resource.data.usuarioId == request.auth.uid || canSupervise(resource.data.jornadaId));
      allow write: if false;
    }

    match /conteos/{conteoId} {
      allow read: if activeUser() &&
        (resource.data.autorUsuarioId == request.auth.uid ||
          canSupervise(resource.data.jornadaId) ||
          assignedToCurrentCorrection(resource.data.jornadaLineaId, conteoId));
      allow create, update, delete: if false;
    }

    match /decisionesRevision/{decisionId} {
      allow read: if activeUser() &&
        (resource.data.autorUsuarioId == request.auth.uid ||
          canSupervise(resource.data.jornadaId) ||
          assignedToCurrentCorrection(resource.data.jornadaLineaId, resource.data.conteoId));
      allow create, update, delete: if false;
    }

    match /reasignacionesCorreccion/{reasignacionId} {
      allow read: if activeUser() && (
        resource.data.autorOriginalUsuarioId == request.auth.uid ||
        resource.data.nuevoUsuarioId == request.auth.uid ||
        canSupervise(resource.data.jornadaId)
      );
      allow create, update, delete: if false;
    }

    match /liberacionesReserva/{liberacionId} {
      allow read: if activeUser() && canSupervise(resource.data.jornadaId);
      allow create, update, delete: if false;
    }

    match /inventarioOficialLineas/{inventarioId} {
      allow read: if canSupervise(resource.data.jornadaId);
      allow create, update, delete: if false;
    }

    match /movimientosInventario/{movimientoId} {
      allow read: if canSupervise(resource.data.jornadaId);
      allow create, update, delete: if false;
    }

    match /idempotencia/{idempotenciaId} {
      allow read, write: if false;
    }

    match /auditoria/{eventoId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
