{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/closing-journey-summary.schema.json",
  "title": "Resumen administrable de una jornada en cierre durable",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jornadaId",
    "nombreVisible",
    "estado",
    "creadorUsuarioId",
    "creadorNombreVisible",
    "version",
    "trabajoCierreId",
    "estadoTrabajo",
    "fase",
    "cursor",
    "cantidadLineas",
    "cantidadOcupaciones",
    "cantidadAutorizaciones",
    "lineasProcesadas",
    "ocupacionesProcesadas",
    "autorizacionesProcesadas",
    "intentos",
    "puedeReintentar",
    "actualizadaEn"
  ],
  "properties": {
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 200},
    "estado": {"const": "CERRANDO"},
    "creadorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "creadorNombreVisible": {"type": "string", "minLength": 1, "maxLength": 200},
    "version": {"type": "integer", "minimum": 2, "maximum": 9007199254740991},
    "trabajoCierreId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "estadoTrabajo": {"enum": ["PENDIENTE", "PROCESANDO", "ERROR"]},
    "fase": {"enum": ["LINEAS", "OCUPACIONES", "AUTORIZACIONES", "FINALIZAR"]},
    "cursor": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "cantidadLineas": {"type": "integer", "minimum": 0, "maximum": 400},
    "cantidadOcupaciones": {"type": "integer", "minimum": 0, "maximum": 400},
    "cantidadAutorizaciones": {"type": "integer", "minimum": 0, "maximum": 400},
    "lineasProcesadas": {"type": "integer", "minimum": 0, "maximum": 400},
    "ocupacionesProcesadas": {"type": "integer", "minimum": 0, "maximum": 400},
    "autorizacionesProcesadas": {"type": "integer", "minimum": 0, "maximum": 400},
    "intentos": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "puedeReintentar": {"type": "boolean"},
    "errorCodigo": {"type": "string", "minLength": 1, "maxLength": 120},
    "errorMensaje": {"type": "string", "minLength": 1, "maxLength": 500},
    "actualizadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  },
  "allOf": [
    {
      "if": {"properties": {"estadoTrabajo": {"const": "ERROR"}}, "required": ["estadoTrabajo"]},
      "then": {
        "properties": {"errorCodigo": true, "errorMensaje": true},
        "required": ["errorCodigo", "errorMensaje"]
      },
      "else": {"properties": {"errorCodigo": false, "errorMensaje": false}}
    }
  ]
}
