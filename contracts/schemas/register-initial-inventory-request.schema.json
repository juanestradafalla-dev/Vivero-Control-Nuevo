{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/register-initial-inventory-request.schema.json",
  "title": "Solicitud de registrarInventarioInicial",
  "type": "object",
  "additionalProperties": false,
  "required": ["lineaId", "versionLineaEsperada", "hembras", "machos", "patrones", "referenciaFuente", "claveIdempotencia"],
  "properties": {
    "lineaId": {"$ref": "comun.schema.json#/$defs/idRutaSegura"},
    "versionLineaEsperada": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "hembras": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "machos": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "patrones": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "referenciaFuente": {"type": "string", "minLength": 1, "maxLength": 500, "description": "Referencia obligatoria que identifica el origen ficticio de la prueba."},
    "claveIdempotencia": {"$ref": "comun.schema.json#/$defs/claveIdempotencia"}
  }
}
