{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/initial-inventory-load.schema.json",
  "title": "Carga inicial inmutable de inventario",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "lineaId", "jornadaId", "jornadaLineaId", "hembras", "machos", "patrones", "total", "versionInventario", "origen", "conteoAprobadoId", "referenciaFuente", "actorUsuarioId", "actorNombreVisible", "registradaEn", "inmutable"],
  "properties": {
    "id": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "lineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaId": {"oneOf": [{"$ref": "comun.schema.json#/$defs/idGlobal"}, {"type": "null"}]},
    "jornadaLineaId": {"oneOf": [{"$ref": "comun.schema.json#/$defs/idGlobal"}, {"type": "null"}]},
    "hembras": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "machos": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "patrones": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "total": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "versionInventario": {"const": 1},
    "origen": {"enum": ["CARGA_INICIAL_ADMINISTRATIVA_EMULADOR", "MIGRACION_CONTROLADA_EMULADOR"]},
    "creadaPorImportacionId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "conteoAprobadoId": {"type": "null"},
    "referenciaFuente": {"type": "string", "minLength": 1, "maxLength": 500},
    "actorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "actorNombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
    "registradaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "inmutable": {"const": true}
  }
}
