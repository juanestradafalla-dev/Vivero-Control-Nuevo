{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/update-draft-journey-lines-request.schema.json",
  "title": "Solicitud actualizarLineasJornadaBorrador",
  "type": "object",
  "additionalProperties": false,
  "required": ["jornadaId", "lineaIds", "claveIdempotencia"],
  "properties": {
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idRutaSegura"},
    "lineaIds": {
      "type": "array",
      "maxItems": 400,
      "uniqueItems": true,
      "items": {"$ref": "comun.schema.json#/$defs/idRutaSegura"}
    },
    "claveIdempotencia": {"$ref": "comun.schema.json#/$defs/claveIdempotencia"}
  }
}
