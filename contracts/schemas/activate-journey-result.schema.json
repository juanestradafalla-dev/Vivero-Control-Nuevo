{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/activate-journey-result.schema.json",
  "title": "Resultado activarJornada",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "jornadaId",
    "estado",
    "version",
    "cantidadLineas",
    "cantidadParticipantes",
    "jornadaLineaIds",
    "participanteIds",
    "activadaEn"
  ],
  "properties": {
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "estado": {"const": "ACTIVA"},
    "version": {"type": "integer", "minimum": 2, "maximum": 9007199254740991},
    "cantidadLineas": {"type": "integer", "minimum": 1, "maximum": 200},
    "cantidadParticipantes": {"type": "integer", "minimum": 1, "maximum": 199},
    "jornadaLineaIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "uniqueItems": true,
      "items": {"$ref": "comun.schema.json#/$defs/idGlobal"}
    },
    "participanteIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 199,
      "uniqueItems": true,
      "items": {"$ref": "comun.schema.json#/$defs/idGlobal"}
    },
    "activadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
