{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/catalog-location-summary.schema.json",
  "title": "Ubicación administrable",
  "type": "object",
  "additionalProperties": false,
  "required": ["ubicacionId", "codigo", "tipo", "ubicacionPadreId", "nombreVisible", "orden", "activa", "version", "cantidadHijosActivos", "cantidadLineasActivas"],
  "properties": {
    "ubicacionId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "codigo": {"type": "string", "minLength": 1, "maxLength": 120},
    "tipo": {"type": "string", "minLength": 1, "maxLength": 80},
    "ubicacionPadreId": {"oneOf": [{"$ref": "comun.schema.json#/$defs/idGlobal"}, {"type": "null"}]},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
    "orden": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "activa": {"type": "boolean"},
    "version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "cantidadHijosActivos": {"type": "integer", "minimum": 0},
    "cantidadLineasActivas": {"type": "integer", "minimum": 0}
  }
}
