{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/catalog-line-result.schema.json",
  "title": "Resultado de crear o actualizar línea",
  "type": "object",
  "additionalProperties": false,
  "required": ["operacion", "lineaId", "ubicacionId", "codigo", "nombreVisible", "orden", "activa", "version", "ocupadaEnJornadaActiva", "seleccionesBorrador", "actualizadaEn"],
  "properties": {
    "operacion": {"enum": ["LINEA_CREADA", "LINEA_ACTUALIZADA"]},
    "lineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "ubicacionId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "codigo": {"type": "string", "minLength": 1, "maxLength": 120},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
    "orden": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "activa": {"type": "boolean"},
    "version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "ocupadaEnJornadaActiva": {"type": "boolean"},
    "seleccionesBorrador": {"type": "integer", "minimum": 0},
    "actualizadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
