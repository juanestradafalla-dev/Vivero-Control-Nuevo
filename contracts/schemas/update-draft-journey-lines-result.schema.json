{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/update-draft-journey-lines-result.schema.json",
  "title": "Resultado actualizarLineasJornadaBorrador",
  "type": "object",
  "additionalProperties": false,
  "required": ["jornadaId", "estado", "version", "cantidadLineas", "lineaIds", "actualizadaEn"],
  "properties": {
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "estado": {"const": "BORRADOR"},
    "version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "cantidadLineas": {"type": "integer", "minimum": 0, "maximum": 400},
    "lineaIds": {
      "type": "array",
      "maxItems": 400,
      "uniqueItems": true,
      "items": {"$ref": "comun.schema.json#/$defs/idRutaSegura"}
    },
    "actualizadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
