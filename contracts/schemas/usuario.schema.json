{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/usuario.schema.json",
  "title": "Usuario",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "roles", "activo", "version", "creadoEn"],
  "properties": {
    "id": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "nombreVisible": {"type": "string", "minLength": 1, "maxLength": 160},
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "../enums/roles.json"}
    },
    "activo": {"type": "boolean"},
    "version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "creadoEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "actualizadoEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
