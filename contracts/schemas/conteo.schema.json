{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/conteo.schema.json",
  "title": "Conteo inmutable aceptado",
  "description": "Registro central inmutable. PENDIENTE_REVISION no modifica inventario oficial y ENVIADA nunca es un estado central.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "jornadaId",
    "jornadaLineaId",
    "lineaId",
    "reservaId",
    "autorUsuarioId",
    "autorNombreVisible",
    "rolEfectivo",
    "dispositivoId",
    "hembras",
    "machos",
    "patrones",
    "total",
    "versionNumero",
    "conteoAnteriorId",
    "claveIdempotencia",
    "timestampDispositivo",
    "recibidoEn",
    "ubicacion",
    "inmutable"
  ],
  "properties": {
    "id": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaLineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "lineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "reservaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "autorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "autorNombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
    "rolEfectivo": {"$ref": "../enums/roles.json"},
    "dispositivoId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "hembras": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "machos": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "patrones": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "plantasMuertas": {"$ref": "comun.schema.json#/$defs/enteroNoNegativo"},
    "total": {
      "allOf": [{"$ref": "comun.schema.json#/$defs/enteroNoNegativo"}],
      "readOnly": true,
      "description": "Calculado centralmente como hembras + machos + patrones."
    },
    "versionNumero": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "conteoAnteriorId": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "comun.schema.json#/$defs/idGlobal"}
      ]
    },
    "claveIdempotencia": {"$ref": "comun.schema.json#/$defs/claveIdempotencia"},
    "observaciones": {"type": "string", "maxLength": 4000},
    "timestampDispositivo": {"type": "string", "format": "date-time"},
    "recibidoEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "ubicacion": {"$ref": "comun.schema.json#/$defs/ubicacionVisible"},
    "inmutable": {"const": true}
  },
  "allOf": [
    {
      "if": {"properties": {"versionNumero": {"const": 1}}, "required": ["versionNumero"]},
      "then": {"properties": {"conteoAnteriorId": {"type": "null"}}}
    },
    {
      "if": {"properties": {"versionNumero": {"type": "integer", "minimum": 2}}, "required": ["versionNumero"]},
      "then": {"properties": {"conteoAnteriorId": {"$ref": "comun.schema.json#/$defs/idGlobal"}}}
    }
  ]
}
