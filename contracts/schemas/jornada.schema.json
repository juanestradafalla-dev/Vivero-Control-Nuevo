{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/jornada.schema.json",
  "title": "Jornada",
  "description": "Agrupa las líneas incluidas en una jornada. La ETAPA 3 solo opera cuando está ACTIVA.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "creadaPorUsuarioId", "estadoAdministrativo", "creadaEn"],
  "properties": {
    "id": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "creadaPorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "estadoAdministrativo": {"$ref": "../enums/estados-jornada.json"},
    "creadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"},
    "cerradaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
