{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/complete-google-drive-oauth-result.schema.json",
  "title": "Resultado de conexion y seleccion Google Drive",
  "type": "object",
  "additionalProperties": false,
  "required": ["estado", "tipoSeleccion", "nombreSeleccion", "actualizadoEn"],
  "properties": {
    "estado": {"enum": ["CONECTADO_INCOMPLETO", "LISTO"]},
    "tipoSeleccion": {"enum": ["PLANTILLA", "CARPETA_SALIDA"]},
    "nombreSeleccion": {"type": "string", "minLength": 1, "maxLength": 240},
    "actualizadoEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
