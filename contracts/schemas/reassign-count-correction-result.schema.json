{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vivero-control.local/contracts/schemas/reassign-count-correction-result.schema.json",
  "title": "ReasignarCorreccionConteoResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reasignacionId",
    "conteoId",
    "jornadaLineaId",
    "autorOriginalUsuarioId",
    "responsableCorreccionUsuarioId",
    "responsableCorreccionNombreVisible",
    "actorUsuarioId",
    "motivo",
    "versionLinea",
    "reasignadaEn"
  ],
  "properties": {
    "reasignacionId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "conteoId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "jornadaLineaId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "autorOriginalUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "responsableCorreccionUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "responsableCorreccionNombreVisible": {"type": "string", "minLength": 1, "maxLength": 240},
    "actorUsuarioId": {"$ref": "comun.schema.json#/$defs/idGlobal"},
    "motivo": {"type": "string", "minLength": 1, "maxLength": 2000},
    "versionLinea": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "reasignadaEn": {"$ref": "comun.schema.json#/$defs/timestampServidor"}
  }
}
